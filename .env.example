# IBM watsonx.ai credentials for the AI Race Engineer (Granite Narrator)
# Get yours at: https://cloud.ibm.com/watsonx-ai
#
# 1. Create a watsonx.ai project at https://dataplatform.cloud.ibm.com
# 2. Generate an API key at https://cloud.ibm.com/iam/apikeys
# 3. Copy your Project ID from the project's "Manage" tab
# 4. Copy this file to .env and fill in your values

WATSONX_API_KEY=your_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
